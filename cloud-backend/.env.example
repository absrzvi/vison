DATABASE_URL=postgresql+asyncpg://oebb:oebb@localhost:5432/oebb
API_KEY=change-me-in-production
# JWT (E11-S1 / ADR-23): REQUIRED in production; empty/unset fails closed
# (no token mints or verifies). The alert-class kill-switch (E10-S1) is now
# JWT role-gated (require_role("admin")) — the old CC_ADMIN_KEY was retired by E11-S4.
JWT_SECRET=change-me-jwt-secret-min-32-chars-long
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8002
