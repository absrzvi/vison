# cloud-sync — pydantic-settings env_prefix is CLOUD_SYNC_

# Upstream event-store (HTTP only; cloud-sync never opens its SQLite directly)
CLOUD_SYNC_EVENT_STORE_URL=http://event-store:8001
CLOUD_SYNC_EVENT_STORE_API_KEY=

# Landside Mosquitto broker
CLOUD_SYNC_MQTT_HOST=mosquitto.landside.local
CLOUD_SYNC_MQTT_PORT=1883
CLOUD_SYNC_MQTT_USERNAME=
CLOUD_SYNC_MQTT_PASSWORD=
CLOUD_SYNC_MQTT_TOPIC_PREFIX=oebb/events

# Local SQLite buffer
CLOUD_SYNC_QUEUE_DB_PATH=/var/lib/cloud-sync/queue.db

# HTTP /health endpoint
CLOUD_SYNC_HOST=0.0.0.0
CLOUD_SYNC_PORT=8082

# Polling + flush behavior
CLOUD_SYNC_PULL_BATCH_SIZE=200
CLOUD_SYNC_PULL_POLL_INTERVAL_S=1.0
CLOUD_SYNC_PUBLISH_RATE_PER_SEC=500
CLOUD_SYNC_ACK_INTERVAL_S=30.0
CLOUD_SYNC_TRUNCATE_RETAIN_JOURNEYS=3
