# fusion container — pydantic-settings env_prefix is FUSION_
FUSION_EVENT_STORE_URL=http://event-store:8000
FUSION_VEHICLE_ID=OBB-TEST
FUSION_SCHEMA_VERSION=1
FUSION_HOST=0.0.0.0
FUSION_PORT=8090

# Accessibility → Ramp correlation TTL (seconds)
FUSION_ACCESSIBILITY_RECENT_WINDOW_S=60.0

# Camera vs APC drift threshold (fraction); ADR-15: log-only, no event emitted
FUSION_CALIBRATION_DRIFT_THRESHOLD=0.10
